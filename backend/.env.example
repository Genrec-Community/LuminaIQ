# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# OpenAI-compatible API Configuration (LLM)
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=z-ai/glm-4.5-air:free

# OpenAI-compatible API Configuration (Embeddings)
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Azure Application Insights Configuration
# Connection string is preferred over instrumentation key
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_INSTRUMENTATION_KEY=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_RETRY_ATTEMPTS=3

# Cache TTL Configuration (in seconds)
CACHE_TTL_EMBEDDING=2592000  # 30 days
CACHE_TTL_QUERY=604800       # 7 days
CACHE_TTL_VECTOR_SEARCH=3600 # 1 hour
CACHE_TTL_DOCUMENT=21600     # 6 hours
CACHE_TTL_SESSION=86400      # 24 hours

# Together AI (optional)
TOGETHER_API_KEY=

# Application Configuration
ENVIRONMENT=development
SECRET_KEY=your-secret-key-change-in-production
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
