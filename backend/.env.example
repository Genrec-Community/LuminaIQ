# ==============================================================================
# LuminaIQ Backend Environment Configuration (.env)
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# 1. SINGLE UNIFIED MODEL API KEY (RECOMMENDED WAY TO SET API KEY)
# ──────────────────────────────────────────────────────────────────────────────
# Set MODEL_API_KEY once — used automatically by both LLM and Embedding services
# if explicit keys below are not provided. Works with Azure OpenAI or OpenRouter/OpenAI.
MODEL_API_KEY=your-model-api-key-here

# ──────────────────────────────────────────────────────────────────────────────
# Option A: Azure OpenAI Configuration (Microsoft Founders Hub / Azure credits)
# ──────────────────────────────────────────────────────────────────────────────
# If using Azure OpenAI, endpoint and deployment names are required:
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ──────────────────────────────────────────────────────────────────────────────
# Option B: Standard / OpenRouter / OpenAI-Compatible Configuration (Fallback)
# ──────────────────────────────────────────────────────────────────────────────
# If AZURE_OPENAI_ENDPOINT is not set, the app falls back to these settings:
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=z-ai/glm-4.5-air:free

EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ──────────────────────────────────────────────────────────────────────────────
# 2. Supabase Configuration (Database & Storage)
# ──────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# ──────────────────────────────────────────────────────────────────────────────
# 3. Vector Database & Cloud OCR
# ──────────────────────────────────────────────────────────────────────────────
# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Azure Computer Vision — OCR for scanned PDFs & image uploads
AZURE_CV_ENDPOINT=https://<region>.api.cognitive.microsoft.com/
AZURE_CV_KEY=

# Optional: Together AI
TOGETHER_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# 4. Application Server Configuration
# ──────────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
SECRET_KEY=your-super-secret-key-change-in-production
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://lumina-iq-livid.vercel.app,https://luminaiq.fun
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
