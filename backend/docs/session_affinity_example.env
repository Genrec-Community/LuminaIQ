# Session Affinity Configuration Example
# This file demonstrates the environment variables needed for horizontal scaling

# ============================================================================
# Instance Identification (Optional - for debugging and monitoring)
# ============================================================================
# Unique identifier for this backend instance
# If not set, defaults to "instance-{pid}"
INSTANCE_ID=backend-instance-1

# ============================================================================
# Redis Configuration (Required - shared across all instances)
# ============================================================================
# Redis host (must be accessible from all backend instances)
REDIS_HOST=lumina-redis.redis.cache.windows.net

# Redis port
REDIS_PORT=6380

# Redis password (use Azure Key Vault in production)
REDIS_PASSWORD=your-redis-password-here

# Redis database number
REDIS_DB=0

# Redis SSL/TLS (recommended for production)
REDIS_SSL=true

# Redis connection pool settings
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5

# ============================================================================
# Session Configuration
# ============================================================================
# Session TTL in seconds (24 hours)
CACHE_TTL_SESSION=86400

# Maximum messages per session
SESSION_MAX_MESSAGES=50

# ============================================================================
# Load Balancer Configuration (Azure Load Balancer)
# ============================================================================
# These are configured on the load balancer, not in the application

# Load balancing algorithm: round_robin
# Health probe endpoint: /health/ready
# Health probe interval: 10 seconds
# Unhealthy threshold: 3 consecutive failures
# Request timeout: 90 seconds

# Session affinity (sticky sessions):
# - Enabled for: /api/v1/chat/stream, /api/v1/progress/*
# - Cookie name: lb-affinity
# - Cookie TTL: 3600 seconds (1 hour)
# - Cookie attributes: HttpOnly, Secure, SameSite=Lax

# ============================================================================
# Monitoring and Observability
# ============================================================================
# Azure Application Insights (for tracking session metrics)
APPINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key-here
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key-here

# Log level
LOG_LEVEL=INFO

# ============================================================================
# Notes
# ============================================================================
# 1. All backend instances MUST use the same Redis connection string
# 2. INSTANCE_ID is optional and only used for debugging
# 3. Session data is stored in Redis with key format: session:{session_id}
# 4. Sessions are accessible from ANY backend instance
# 5. Session affinity is ONLY needed for SSE/WebSocket endpoints
# 6. Regular REST API requests do NOT require session affinity
