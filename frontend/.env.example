# ==============================================================================
# LuminaIQ Frontend Environment Configuration (.env)
# ==============================================================================

# 1. Backend API Endpoint
# Local Development: http://localhost:8000/api/v1
# Production (Render/AWS/Azure): https://your-backend-app.onrender.com/api/v1
VITE_MAIN_API_URL=http://localhost:8000/api/v1

# 2. Supabase Configuration (Authentication & Client APIs)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
